{
  "name": "postcommit",
  "version": "0.1.0",
  "description": "Drafts build-in-public tweets from your recent git commits.",
  "type": "module",
  "bin": {
    "postcommit": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun src/index.ts",
    "build": "tsc",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src tests"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^13.0.0",
    "enquirer": "^2.4.1",
    "execa": "^9.5.2",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^22.10.0",
    "oxlint": "^0.15.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22"
  }
}
